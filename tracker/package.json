{
  "name": "@openstreamgrid/tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-dashboard.mjs dist",
    "start": "node dist/server.js",
    "dev": "node --experimental-strip-types src/server.ts",
    "test": "tsc -p tsconfig.test.json && node scripts/copy-dashboard.mjs dist-test/src && node --test dist-test/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openstreamgrid/common": "0.2.0",
    "better-sqlite3": "^12.11.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1"
  }
}
