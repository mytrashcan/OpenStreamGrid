{
  "name": "@openstreamgrid/sdk",
  "version": "0.4.0",
  "description": "OpenStreamGrid Browser SDK — hybrid P2P-CDN live streaming middleware for Hls.js",
  "type": "module",
  "main": "./dist/sdk.cjs",
  "module": "./dist/sdk.js",
  "types": "./dist/types/index.d.ts",
  "browser": "./dist/sdk.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/sdk.js",
      "import": "./dist/sdk.js",
      "require": "./dist/sdk.cjs"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "npm run typecheck && tsc -p tsconfig.json --emitDeclarationOnly && node scripts/build.mjs",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "hls.js": "^1.5.0"
  },
  "devDependencies": {
    "@openstreamgrid/common": "file:../common",
    "@roamhq/wrtc": "^0.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "p2p",
    "hls",
    "hlsjs",
    "live-streaming",
    "cdn",
    "webrtc"
  ],
  "license": "MIT"
}
